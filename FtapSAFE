    local fi=Instance.new("Frame",tr); fi.Size=UDim2.new((def-mn)/(mx-mn),0,1,0)
    fi.BackgroundColor3=Color3.fromRGB(200,200,200); fi.BorderSizePixel=0; fi.ZIndex=15
    Instance.new("UICorner",fi).CornerRadius=UDim.new(1,0)
    local kn=Instance.new("Frame",tr); kn.Size=UDim2.new(0,14,0,14); kn.AnchorPoint=Vector2.new(0.5,0.5)
    kn.Position=UDim2.new((def-mn)/(mx-mn),0,0.5,0); kn.BackgroundColor3=Color3.fromRGB(240,240,240); kn.BorderSizePixel=0; kn.ZIndex=16
    Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)
    local drag=false
    local function upd(x)
        local t2=math.clamp((x-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
        local v=math.floor(mn+t2*(mx-mn))
        fi.Size=UDim2.new(t2,0,1,0); kn.Position=UDim2.new(t2,0,0.5,0); vl.Text=tostring(v); Safe(function() onChange(v) end)
    end
    local sb=Instance.new("TextButton",card); sb.Size=UDim2.new(1,-28,0,26); sb.Position=UDim2.new(0,14,0,34)
    sb.BackgroundTransparency=1; sb.Text=""; sb.ZIndex=17
    sb.MouseButton1Down:Connect(function() drag=true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
    sb.MouseButton1Click:Connect(function() upd(UserInputService:GetMouseLocation().X) end)
    return card
end

