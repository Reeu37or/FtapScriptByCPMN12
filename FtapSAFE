    for _,v in pairs(radarObjs) do Safe(function() v:Remove() end) end; radarObjs={}
    if on then
        local vp=Camera.ViewportSize
        local bg=Drawing.new("Circle"); bg.Visible=true; bg.Filled=true; bg.NumSides=64
        bg.Color=Color3.fromRGB(8,8,8); bg.Transparency=0.4; bg.Radius=RADAR_SIZE/2
        bg.Position=Vector2.new(vp.X-RADAR_SIZE/2-14,vp.Y-RADAR_SIZE/2-14); radarObjs.bg=bg
        local bgE=Drawing.new("Circle"); bgE.Visible=true; bgE.Filled=false; bgE.NumSides=64
        bgE.Color=Color3.fromRGB(70,70,70); bgE.Thickness=1.2; bgE.Radius=RADAR_SIZE/2; bgE.Position=bg.Position; radarObjs.bgE=bgE
        local rl=Drawing.new("Line"); rl.Color=Color3.fromRGB(50,50,50); rl.Thickness=1; rl.Visible=true
        rl.From=Vector2.new(bg.Position.X-RADAR_SIZE/2,bg.Position.Y); rl.To=Vector2.new(bg.Position.X+RADAR_SIZE/2,bg.Position.Y); radarObjs.rl=rl
        local cl=Drawing.new("Line"); cl.Color=Color3.fromRGB(50,50,50); cl.Thickness=1; cl.Visible=true
        cl.From=Vector2.new(bg.Position.X,bg.Position.Y-RADAR_SIZE/2); cl.To=Vector2.new(bg.Position.X,bg.Position.Y+RADAR_SIZE/2); radarObjs.cl=cl
        local sd=Drawing.new("Circle"); sd.Visible=true; sd.Filled=true; sd.NumSides=8
        sd.Color=Color3.fromRGB(255,255,255); sd.Radius=3; sd.Position=bg.Position; radarObjs.sd=sd
        radarObjs.dots={}
        radarConn=RunService.RenderStepped:Connect(function()
            Safe(function()
                local hrp=GetHRP(); if not hrp then return end
                local vp2=Camera.ViewportSize
                local center=Vector2.new(vp2.X-RADAR_SIZE/2-14,vp2.Y-RADAR_SIZE/2-14)
                bg.Position=center; bgE.Position=center; sd.Position=center
                rl.From=Vector2.new(center.X-RADAR_SIZE/2,center.Y); rl.To=Vector2.new(center.X+RADAR_SIZE/2,center.Y)
                cl.From=Vector2.new(center.X,center.Y-RADAR_SIZE/2); cl.To=Vector2.new(center.X,center.Y+RADAR_SIZE/2)
                for _,d in ipairs(radarObjs.dots) do Safe(function() d:Remove() end) end; radarObjs.dots={}
                local myCF=hrp.CFrame
                for _,p in ipairs(Players:GetPlayers()) do
                    if p==LP then continue end
                    Safe(function()
                        local tc=p.Character; if not tc then return end
                        local th=tc:FindFirstChild("HumanoidRootPart"); if not th then return end
                        local rel=myCF:ToObjectSpace(CFrame.new(th.Position))
                        local dx,dz=rel.Position.X,rel.Position.Z
                        if math.sqrt(dx*dx+dz*dz)<RADAR_RANGE then
                            local dot=Drawing.new("Circle"); dot.Visible=true; dot.Filled=true; dot.NumSides=8
                            dot.Color=Color3.fromRGB(220,220,220); dot.Radius=4
                            dot.Position=Vector2.new(center.X+(dx/RADAR_RANGE)*(RADAR_SIZE/2),center.Y+(dz/RADAR_RANGE)*(RADAR_SIZE/2))
                            table.insert(radarObjs.dots,dot)
                        end
                    end)
                end
            end)
        end)
        SetActive("Radar",true); Notify("Radar","Включён ✓")
    else SetActive("Radar",false); Notify("Radar","Выключен") end
end

