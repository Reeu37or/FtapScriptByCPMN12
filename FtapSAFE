--   BIND SYSTEM
-- ════════════════════════════════════════════════════════
local FnBinds     = {}
local FnStates    = {}
local FnCallbacks = {}

local function RegFn(name, cb)
    FnCallbacks[name] = cb
    FnStates[name]    = false
end

local function ToggleFn(name)
    if not FnCallbacks[name] then return end
    FnStates[name] = not FnStates[name]
    Safe(function() FnCallbacks[name](FnStates[name]) end)
end

local function SetActive(name, on)
    if on then S.ActiveFns[name]=true else S.ActiveFns[name]=nil end
end

