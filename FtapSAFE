    o.dist=Drawing.new("Text"); o.dist.Size=11; o.dist.Center=true; o.dist.Outline=true; o.dist.Visible=false
    o.skel={}; for _,pair in ipairs(SKEL) do local l=Drawing.new("Line"); l.Thickness=1; l.Visible=false; table.insert(o.skel,{l=l,a=pair.a,b=pair.b}) end
    ESPO[p]=o; return o
end

local function KillESP(p)
    local o=ESPO[p]; if not o then return end
    Safe(function() o.box:Remove(); o.name:Remove(); o.hpbar:Remove(); o.hpbg:Remove(); o.dist:Remove() end)
    for _,c in ipairs(o.corners) do Safe(function() c:Remove() end) end
    for _,s in ipairs(o.spirits) do Safe(function() s:Remove() end) end
    for _,s in ipairs(o.skel) do Safe(function() s.l:Remove() end) end
    ESPO[p]=nil
end

