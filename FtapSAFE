    while notifSlots[slot] do slot=slot+1 end
    notifSlots[slot] = true
    local baseY = -(60+(slot-1)*64)

    local nf = Instance.new("Frame",SG)
    nf.Size=UDim2.new(0,270,0,54); nf.Position=UDim2.new(1,20,1,baseY)
