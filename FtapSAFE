-- ── TOGGLE с встроенным биндом ──
local function MakeToggle(par, label, desc, onToggle, fnName)
    local h = desc and 58 or 48
    local card = MakeCard(par, h)

    local lbl=Instance.new("TextLabel",card); lbl.Size=UDim2.new(1,-110,0,20)
    lbl.Position=UDim2.new(0,14,0, desc and 8 or 14); lbl.BackgroundTransparency=1
    lbl.Text=label; lbl.Font=Enum.Font.GothamSemibold; lbl.TextSize=13
    lbl.TextColor3=Color3.fromRGB(215,215,215); lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=14

    if desc then
        local dl=Instance.new("TextLabel",card); dl.Size=UDim2.new(1,-110,0,14); dl.Position=UDim2.new(0,14,0,30)
        dl.BackgroundTransparency=1; dl.Text=desc; dl.Font=Enum.Font.Gotham; dl.TextSize=10
        dl.TextColor3=Color3.fromRGB(75,75,75); dl.TextXAlignment=Enum.TextXAlignment.Left; dl.ZIndex=14
    end

    -- switch
    local swBG=Instance.new("Frame",card); swBG.Size=UDim2.new(0,36,0,20); swBG.Position=UDim2.new(1,-100,0.5,-10)
    swBG.BackgroundColor3=Color3.fromRGB(34,34,34); swBG.BorderSizePixel=0; swBG.ZIndex=14
    Instance.new("UICorner",swBG).CornerRadius=UDim.new(1,0)
    local swD=Instance.new("Frame",swBG); swD.Size=UDim2.new(0,14,0,14); swD.Position=UDim2.new(0,3,0.5,-7)
    swD.BackgroundColor3=Color3.fromRGB(82,82,82); swD.BorderSizePixel=0; swD.ZIndex=15
    Instance.new("UICorner",swD).CornerRadius=UDim.new(1,0)

    -- bind button
    local bb=Instance.new("TextButton",card); bb.Size=UDim2.new(0,52,0,22); bb.Position=UDim2.new(1,-56,0.5,-11)
    bb.BackgroundColor3=Color3.fromRGB(22,22,22); bb.BorderSizePixel=0
    bb.Text="Бинд"; bb.Font=Enum.Font.GothamBold; bb.TextSize=9
    bb.TextColor3=Color3.fromRGB(100,100,100); bb.ZIndex=15
    Instance.new("UICorner",bb).CornerRadius=UDim.new(0,6)
    local bbs=Instance.new("UIStroke",bb); bbs.Color=Color3.fromRGB(40,40,40); bbs.Thickness=1

    local enabled=false
    local function setVis(v)
        if v then
            TW(swBG,{BackgroundColor3=Color3.fromRGB(195,195,195)},0.17)
            TW(swD,{Position=UDim2.new(0,19,0.5,-7),BackgroundColor3=Color3.fromRGB(11,11,11)},0.17)
        else
            TW(swBG,{BackgroundColor3=Color3.fromRGB(34,34,34)},0.17)
            TW(swD,{Position=UDim2.new(0,3,0.5,-7),BackgroundColor3=Color3.fromRGB(82,82,82)},0.17)
        end
    end

    local hit=Instance.new("TextButton",card); hit.Size=UDim2.new(1,-110,1,0)
    hit.BackgroundTransparency=1; hit.Text=""; hit.ZIndex=16
    hit.MouseButton1Click:Connect(function()
        enabled=not enabled; setVis(enabled)
        Safe(function() onToggle(enabled) end)
        if fnName then FnStates[fnName]=enabled end
    end)

    -- bind logic
    if fnName then
        local waiting=false
        bb.MouseButton1Click:Connect(function()
            waiting=true; bb.Text="..."; bb.TextColor3=Color3.fromRGB(220,220,220)
            TW(bb,{BackgroundColor3=Color3.fromRGB(40,40,40)},0.1)
            bbs.Color=Color3.fromRGB(130,130,130)
        end)
        bb.MouseButton2Click:Connect(function()
            FnBinds[fnName]=nil; bb.Text="Бинд"; bb.TextColor3=Color3.fromRGB(100,100,100)
            TW(bb,{BackgroundColor3=Color3.fromRGB(22,22,22)},0.1); bbs.Color=Color3.fromRGB(40,40,40)
            waiting=false; Notify("Бинд убран",fnName)
        end)
        UserInputService.InputBegan:Connect(function(inp,gp)
            if not waiting or gp then return end
            if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
            waiting=false
            FnBinds[fnName]=inp.KeyCode
            local n=inp.KeyCode.Name; local sh=n; if #sh>7 then sh=sh:sub(1,6).."…" end
            bb.Text=sh; bb.TextColor3=Color3.fromRGB(180,180,180)
            TW(bb,{BackgroundColor3=Color3.fromRGB(22,22,22)},0.1); bbs.Color=Color3.fromRGB(40,40,40)
            Notify("Бинд",fnName.." → "..n)
        end)
        RegFn(fnName, function(v)
            enabled=v; setVis(v)
            Safe(function() onToggle(v) end)
        end)
    end

    return card, function(v) enabled=v; setVis(v); if fnName then FnStates[fnName]=v end end
end

local function MakeSlider(par,label,mn,mx,def,onChange)
