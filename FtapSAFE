local function GetESP(p)
    if ESPO[p] then return ESPO[p] end
    local o={}
    o.box=Drawing.new("Square"); o.box.Filled=false; o.box.Thickness=1.5; o.box.Visible=false
    o.corners={}; for i=1,8 do local l=Drawing.new("Line"); l.Thickness=2.2; l.Visible=false; o.corners[i]=l end
    o.spirits={}; for i=1,3 do local l=Drawing.new("Line"); l.Thickness=2.5; l.Visible=false; o.spirits[i]=l end
    o.name=Drawing.new("Text"); o.name.Size=13; o.name.Center=true; o.name.Outline=true; o.name.Visible=false
    o.hpbar=Drawing.new("Line"); o.hpbar.Thickness=3; o.hpbar.Visible=false
